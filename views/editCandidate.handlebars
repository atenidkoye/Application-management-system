<h1>Edit Candidate</h1>

<form action="/routes/update/{{candidate._id}} method=POST">
    <input type="text" name="name" value="{{candidate.name}}" required/>
    <input type="email" name="name"email="{{candidate.email}}" required/>
    <input type="text" name="skills"email="{{candidate.skills}}" required/>

    <button type="submit">Update</button>
</form>