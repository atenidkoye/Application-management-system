<form id="new-note-form" class="note-container editable" method="POST">
    <style>
        .note-container {
            width: 250px;
            height: 250px;
            background-color: rgb(255, 255, 255);
            padding: 10px;
            box-sizing: border-box;
            border-radius: 10px;
            border: 1px solid gray;
            box-shadow: 1px 1px 2px 2px rgba(0, 0, 0, 0.263);
        }

        form.editable {
            height: 300px;
        }

        .note-text {
            font-size: 18px;
            height: 200px;
            width: 100%;
            resize: none;
            padding: 5px;
        }

        .readOnly .note-text {
            cursor: default;
            outline: none;
        }

        .editable .note-text:focus {
            outline: 3px solid blue;
        }

        .rating {
            font-size: 22px;
            display: flex;
            justify-content: center;
            margin: 5px 0;
        }

        .star {
            -webkit-text-stroke: 1px black;
            padding: 0 5px;
        }

        span.readOnly {
            cursor: default;
        }

        span.editable {
            cursor: pointer;
        }

        .off {
            color: black;
        }

        .hover {
            color: rgb(152, 152, 22);
        }

        .on {
            color: yellow;
        }

        .submit-button {
            width: 100%;
            font-size: 20px;
            padding: 5px;
        }
        
    </style>

    <textarea class="note-text" placeholder="Thoughts about the application..."></textarea>
    <div class="rating">
        <span class="star editable">★</span>
        <span class="star editable">★</span>
        <span class="star editable">★</span>
        <span class="star editable">★</span>
        <span class="star editable">★</span>
    </div>
    <button class="submit-button" type="submit">Share thoughts</button>
</form>